{
  "name": "botanical-twin",
  "version": "2.0.0",
  "description": "Botanical Twin — Dashboard + FastMCP server + ESP8266 MQTT bridge",
  "type": "module",
  "scripts": {
    "dashboard":  "node dashboard_server.js",
    "mcp":        "node botanical-twin-fastmcp.js",
    "mcp:sse":    "MCP_TRANSPORT=sse MCP_PORT=3001 node botanical-twin-fastmcp.js"
  },
  "dependencies": {
    "dotenv":                    "^16.0.0",
    "fastmcp":                   "^3.0.0",
    "mqtt":                      "^5.0.0",
    "zod":                       "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  }
}